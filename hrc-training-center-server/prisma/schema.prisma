datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String         @id @default(uuid()) @db.Uuid
  pID             String?        @unique @db.VarChar(12)
  fullname        String
  email           String         @unique
  phone           String         @unique
  password        String
  avatar          String?
  gender          Gender?
  dob             DateTime?      @db.Date
  status          UserStatus     @default(ACTIVE)
  isEmailVerified Boolean        @default(false)
  lockoutEnd      DateTime?
  lastLogin       DateTime?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  refreshTokens   RefreshToken[]
  enrollments     Enrollment[]
  roles           Role[]         @relation("UserRoles")
  createdInvoices Invoice[]      @relation("CreatedInvoices")
  paidInvoices    Invoice[]      @relation("PaidInvoices")
  taughtBatches   Batch[]        @relation("TeacherBatches")
  createdBatches  Batch[]        @relation("CreatorBatches")

  @@map("users")
}

model Role {
  id          Int          @id @default(autoincrement())
  shortname   String       @unique
  fullname    String       @unique
  level       Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  parentRoles Role[]       @relation("RoleHierarchy")
  childRoles  Role[]       @relation("RoleHierarchy")
  permissions Permission[] @relation("RolePermissions")
  status      RoleStatus   @default(ACTIVE)
  users       User[]       @relation("UserRoles")

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  action      String
  resource    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("RolePermissions")

  @@map("permissions")
}

model RefreshToken {
  id              Int         @id @default(autoincrement())
  token           String      @unique
  user            User        @relation(fields: [userId], references: [id])
  userId          String      @db.Uuid
  expiresAt       DateTime
  status          TokenStatus @default(ACTIVE)
  replacedTokenId String?     @db.VarChar(255)
  ipAddress       String?     @db.VarChar(45)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("refresh_tokens")
}

model Course {
  id           Int          @id @default(autoincrement())
  code         String       @unique
  slug         String       @unique
  name         String
  description  String?
  duration     String
  coverImage   String?
  objectives   Json
  audiences    Json
  requirements Json
  schedule     Json
  // locations    Json
  assessments  Json
  materials    Json
  contents     Json
  instructors  Json
  price        Decimal      @db.Decimal(12, 2)
  minSize      Int          @default(0)
  maxSize      Int?
  totalLessons Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  batches      Batch[]
  sessions     Session[]
  status       CourseStatus @default(ACTIVE)
  category     Category[]   @relation()

  @@map("courses")
}

model Category {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String?
  status      CategoryStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  courses     Course[]

  @@map("categories")
}

model Session {
  id       Int           @id @default(autoincrement())
  course   Course        @relation(fields: [courseId], references: [id])
  courseId Int
  lessons  Lesson[]
  status   SessionStatus @default(ACTIVE)

  @@map("sessions")
}

model Shift {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  startTime   Int
  endTime     Int
  status      ShiftStatus @default(ACTIVE)
  batches     Batch[]

  @@map("shifts")
}

model Batch {
  id           Int          @id @default(autoincrement())
  batchCode    String       @unique
  name         String
  type         BatchType    @default(ONLINE)
  currentSize  Int          @default(0)
  minSize      Int          @default(0)
  maxSize      Int?
  teachers     User[]       @relation("TeacherBatches")
  totalLessons Int          @default(0)
  price        Decimal      @db.Decimal(12, 2)
  description  String?
  enrollments  Enrollment[]
  startDate    DateTime
  endDate      DateTime
  status       BatchStatus  @default(WAITING)
  course       Course?      @relation(fields: [courseId], references: [id])
  courseId     Int?
  shift        Shift?       @relation(fields: [shiftId], references: [id])
  shiftId      Int?
  lessons      Lesson[]
  date         DayOfWeek[]
  createdBy    User         @relation("CreatorBatches", fields: [createdById], references: [id])
  createdById  String       @db.Uuid
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("batches")
}

model Lesson {
  id        Int          @id @default(autoincrement())
  batch     Batch        @relation(fields: [batchId], references: [id])
  batchId   Int
  session   Session      @relation(fields: [sessionId], references: [id])
  sessionId Int
  status    LessonStatus @default(WAITING)
  startTime DateTime     @db.Timestamptz
  endTime   DateTime     @db.Timestamptz
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("lessons")
}

model Enrollment {
  id        Int              @id @default(autoincrement())
  student   User             @relation(fields: [studentId], references: [id])
  studentId String           @db.Uuid
  batch     Batch?           @relation(fields: [batchId], references: [id])
  batchId   Int?
  status    EnrollmentStatus @default(WAITING)
  invoice   Invoice          @relation(fields: [invoiceId], references: [id])
  invoiceId Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([studentId, batchId])
  @@map("enrollments")
}

model Invoice {
  id             Int           @id @default(autoincrement())
  invoiceCode    String        @unique
  enrollment     Enrollment[]
  amount         Decimal       @db.Decimal(12, 2)
  createdBy      User          @relation("CreatedInvoices", fields: [createdById], references: [id])
  createdById    String        @db.Uuid
  note           String?
  paidUser       User?         @relation("PaidInvoices", fields: [paidUserId], references: [id])
  paidUserId     String?       @db.Uuid
  totalAmount    Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @db.Decimal(12, 2)
  finalAmount    Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @db.Decimal(12, 2)
  currency       String
  status         InvoiceStatus
  payments       Payment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("invoices")
}

model Payment {
  id            Int           @id @default(autoincrement())
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  invoiceId     Int
  method        PaymentMethod
  transactionId String?
  amount        Decimal       @db.Decimal(12, 2)
  currency      String
  evidenceImage String[]
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([method, transactionId])
  @@map("payments")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserStatus {
  ACTIVE
  DELETED
  BANNED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
}

enum TokenStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum EnrollmentStatus {
  WAITING
  APPROVED
  REJECTED
  CANCELED
  ONGOING
  COMPLETED
  PENDING
}

enum CourseStatus {
  ACTIVE
  ARCHIVED
  INACTIVE
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum BatchType {
  ONLINE
  OFFLINE
  HYBRID
}

enum BatchStatus {
  WAITING
  DISABLED
  ONGOING
  COMPLETED
}

enum LessonStatus {
  WAITING
  ONGOING
  COMPLETED
  CANCELED
}

enum SessionStatus {
  ACTIVE
  INACTIVE
}

enum ShiftStatus {
  ACTIVE
  INACTIVE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  PAYPAL
  CASH
  MOMO
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
